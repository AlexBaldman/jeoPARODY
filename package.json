{
  "name": "JeoPARODY",
  "version": "2.1.0",
  "description": "A comedic Jeopardy-style trivia game with AI-powered host",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "analyze": "vite build --mode analyze",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "mcp:browser": "npx -y @modelcontextprotocol/server-browser",
    "mcp:chrome": "npx -y @modelcontextprotocol/server-chrome",
    "chrome:rdp": "powershell -ExecutionPolicy Bypass -File scripts/start-chrome-rdp.ps1",
    "snap": "node scripts/playwright-sample.mjs",
    "purge:css": "purgecss --config purgecss.config.cjs --output dist/assets",
    "scan:todos": "node scripts/scan-todos.js ."
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "@google/generative-ai": "^0.21.0",
    "eslint": "^8.57.1",
    "firebase": "^11.6.1"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.9.1",
    "@babel/preset-env": "^7.28.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-legacy": "^6.1.1",
    "babel-jest": "^30.0.4",
    "gh-pages": "^6.3.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.1.2",
    "purgecss": "^6.0.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.0",
    "vite": "^6.3.5"
  }
}